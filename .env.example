# Copy to .env and fill in real values. Never commit .env.
#
#   cp .env.example .env
#
# Every variable marked REQUIRED is validated at start-up; the process refuses
# to boot if one is missing or empty.

# =============================================================================
# 1. SERVER
# =============================================================================
HOST=0.0.0.0
PORT=8080

# =============================================================================
# 2. POSTGRES (also consumed by docker-compose.yml)
# =============================================================================
POSTGRES_USER=eng_os_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=eng_os_db
POSTGRES_PORT=5432

# REQUIRED — must match the credentials above when using docker-compose.
DATABASE_URL=postgres://eng_os_user:change_me@localhost:5432/eng_os_db

# Connection pool tuning (optional).
DB_MAX_CONNECTIONS=20
DB_ACQUIRE_TIMEOUT_SECS=5

# =============================================================================
# 3. REDIS — conversation state, per-user locks, webhook deduplication
# =============================================================================
# REQUIRED
REDIS_URL=redis://127.0.0.1:6379

# =============================================================================
# 4. GEMINI — https://aistudio.google.com/
# =============================================================================
# REQUIRED
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# 5. LINE MESSAGING API
#    https://developers.line.biz/ -> your Messaging API channel
# =============================================================================
# REQUIRED — verifies the x-line-signature header on every webhook request.
# Without it the endpoint cannot be authenticated, so it is mandatory.
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# REQUIRED — used to send replies and push messages.
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# =============================================================================
# 6. AI USAGE REPORT (optional)
#    Only used to render the "5. สถิติการใช้ AI" report. Nothing is enforced —
#    this is a personal tool, so the point is visibility, not rationing.
# =============================================================================
# Token allowance the report measures "remaining" against.
AI_TOKEN_BUDGET=1000000

# USD per million tokens, used to turn token counts into a rough cost estimate.
# Check these against current Google pricing for the model you run.
AI_PRICE_INPUT_PER_MTOK=0.30
AI_PRICE_OUTPUT_PER_MTOK=2.50

# =============================================================================
# 7. LOGGING (optional)
# =============================================================================
# Defaults to engos_tool_rs=info,tower_http=warn,sqlx=warn
RUST_LOG=engos_tool_rs=info

# Set to "json" for structured output in deployed environments.
LOG_FORMAT=
