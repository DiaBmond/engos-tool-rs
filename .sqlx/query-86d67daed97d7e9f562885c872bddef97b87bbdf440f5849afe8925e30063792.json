  "query": "\n            SELECT\n                COUNT(*)                       AS \"calls!\",\n                COALESCE(SUM(prompt_tokens), 0) AS \"prompt!\",\n                COALESCE(SUM(output_tokens), 0) AS \"output!\",\n                COALESCE(SUM(total_tokens), 0)  AS \"total!\"\n            FROM ai_usage\n            WHERE created_at >= NOW() - $1::interval\n            ",
