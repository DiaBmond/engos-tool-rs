  "query": "\n            SELECT\n                feature,\n                COUNT(*)                      AS \"calls!\",\n                COALESCE(SUM(total_tokens), 0) AS \"total!\"\n            FROM ai_usage\n            WHERE created_at >= NOW() - $1::interval\n            GROUP BY feature\n            ORDER BY 3 DESC\n            ",
