  "query": "\n            INSERT INTO vocabs (vocab_id, word, definition, category)\n            VALUES ($1, $2, $3, $4)\n            ON CONFLICT (word, category) DO UPDATE\n            SET definition = EXCLUDED.definition\n            RETURNING vocab_id, word, definition, category\n            ",
